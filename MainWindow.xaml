<Window x:Class="CybersecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot — POE"
        Height="780" Width="1024"
        MinHeight="640" MinWidth="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Stay alert. Stay secure. Stay informed."
                               FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock x:Name="UserNameLabel" Text="Guest"
                               FontSize="14" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right"/>
                    <Button x:Name="PlayGreetingButton" Content="Play Greeting"
                            Margin="0,8,0,0" Padding="12,6"
                            Background="{StaticResource SecondaryBrush}"
                            Foreground="{StaticResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Click="PlayGreetingButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main tabs: Chat, Tasks, Quiz, Activity Log -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Chat" FontSize="14" Padding="12,6">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8">
                        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChatPanel" Margin="4"/>
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox"
                                 Grid.Column="0"
                                 MinHeight="40" Padding="12,10"
                                 FontSize="14"
                                 Background="{StaticResource InputBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 BorderBrush="{StaticResource SecondaryBrush}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 KeyDown="InputBox_KeyDown"/>
                        <Button x:Name="SendButton" Grid.Column="1"
                                Content="Send" MinWidth="100" Margin="8,0,0,0"
                                Padding="16,10" FontSize="14" FontWeight="SemiBold"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="{StaticResource OutcomeTextDarkBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks" FontSize="14" Padding="12,6">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Add Cybersecurity Task" FontWeight="SemiBold" FontSize="15"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Title" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskTitleBox" Padding="8" Margin="0,0,0,8"
                                     Background="{StaticResource InputBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SecondaryBrush}"/>
                            <TextBlock Text="Description" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskDescBox" Padding="8" MinHeight="60" TextWrapping="Wrap"
                                     AcceptsReturn="True" Margin="0,0,0,8"
                                     Background="{StaticResource InputBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource SecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Reminder (optional)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="TaskReminderPicker" Padding="4"
                                                Background="{StaticResource InputBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Add Task" VerticalAlignment="Bottom"
                                        Margin="12,0,0,0" Padding="16,8"
                                        Background="{StaticResource PrimaryBrush}"
                                        Foreground="{StaticResource OutcomeTextDarkBrush}"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="AddTaskButton_Click"/>
                            </Grid>
                            <TextBlock x:Name="TaskDbStatusLabel" Margin="0,8,0,0"
                                       Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8">
                        <DataGrid x:Name="TasksGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}"
                                  RowBackground="{StaticResource PanelBrush}"
                                  AlternatingRowBackground="{StaticResource InputBrush}"
                                  HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                                  BorderBrush="{StaticResource GridLineBrush}" BorderThickness="1"
                                  RowHeaderWidth="0" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                                <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDisplay}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsCompleted}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Mark Complete" Padding="12,8" Margin="0,0,8,0"
                                Background="{StaticResource SuccessBrush}"
                                Foreground="{StaticResource OutcomeTextLightBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="CompleteTaskButton_Click"/>
                        <Button Content="Delete Task" Padding="12,8" Margin="0,0,8,0"
                                Background="{StaticResource ErrorBrush}"
                                Foreground="{StaticResource OutcomeTextLightBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="DeleteTaskButton_Click"/>
                        <Button Content="Refresh" Padding="12,8"
                                Background="{StaticResource SecondaryBrush}"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="RefreshTasksButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz" FontSize="14" Padding="12,6">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Cybersecurity Mini-Game" FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Test your knowledge with multiple-choice and true/false questions."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                            <TextBlock x:Name="QuizProgressLabel" Text="Press Start to begin (5 questions)"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="QuizQuestionLabel" TextWrapping="Wrap"
                                       FontSize="15" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                            <StackPanel x:Name="QuizOptionsPanel"/>
                            <TextBlock x:Name="QuizFeedbackLabel" TextWrapping="Wrap" Margin="0,16,0,0"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="StartQuizButton" Content="Start Quiz" Padding="16,8" Margin="0,0,8,0"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="{StaticResource OutcomeTextDarkBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="StartQuizButton_Click"/>
                        <Button x:Name="NextQuizButton" Content="Next Question" Padding="16,8"
                                IsEnabled="False"
                                Background="{StaticResource SecondaryBrush}"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="NextQuizButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log" FontSize="14" Padding="12,6">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <TextBlock Text="Recent bot actions — tasks, reminders, quiz, and NLP interactions."
                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8">
                        <ListBox x:Name="ActivityLogList" BorderThickness="0"
                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                 FontSize="13" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock x:Name="ActivityLogCountLabel" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,12,0"/>
                        <Button x:Name="ShowMoreLogButton" Content="Show More" Padding="16,8"
                                Background="{StaticResource SecondaryBrush}"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Cursor="Hand"
                                Click="ShowMoreLogButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
